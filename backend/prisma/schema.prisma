// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id              Int       @id @default(autoincrement())
  nombre          String
  correo          String    @unique
  contrasena      String
  telefono        String
  rol             String
  estado          String    @default("pendiente")
  intentosFallidos Int      @default(0)
  bloqueadoHasta  DateTime?
  fechaCreacion   DateTime  @default(now())

  banda           Banda?
  organizador     Organizador?
  mensajes        Mensaje[]
}

model Organizador {
  id            Int         @id @default(autoincrement())
  usuarioId     Int         @unique
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])
  fechaCreacion DateTime    @default(now())
  solicitudes   Solicitud[]
  resenas       Resena[]
}

model Banda {
  id                   Int               @id @default(autoincrement())
  usuarioId            Int               @unique
  usuario              Usuario           @relation(fields: [usuarioId], references: [id])
  municipio            String
  departamento         String?
  nit                  String?
  estadoVerificacion   String            @default("borrador")
  integrantes          String?
  generos              String?
  municipiosCobertura  String?
  aniosExperiencia     Int               @default(0)
  estadoPerfil         String            @default("borrador")
  rangoPrecio          String?
  banco                String?
  tipoCuenta           String?
  numeroCuenta         String?
  multimedia           MultimediaBanda[]
  disponibilidad       DisponibilidadBanda[]
  solicitudes          Solicitud[]
  resenas              Resena[]
}

model Solicitud {
  id             Int          @id @default(autoincrement())
  bandaId        Int
  banda          Banda        @relation(fields: [bandaId], references: [id])
  organizadorId  Int
  organizador    Organizador  @relation(fields: [organizadorId], references: [id])
  fecha          DateTime
  franjaInicio   String
  franjaFin      String
  municipio      String
  tipoEvento     String
  duracionHoras  Int
  presupuesto    Float
  estado         String       @default("pendiente")
  contraOferta   String?
  fechaCreacion  DateTime     @default(now())
  mensajes       Mensaje[]
  resena         Resena?
  pago           Pago?
}

model DisponibilidadBanda {
  id            Int      @id @default(autoincrement())
  bandaId       Int
  banda         Banda    @relation(fields: [bandaId], references: [id])
  fecha         DateTime
  franjaInicio  String
  franjaFin     String
  estado        String   @default("disponible")
}

model MultimediaBanda {
  id          Int      @id @default(autoincrement())
  bandaId     Int
  banda       Banda    @relation(fields: [bandaId], references: [id])
  url         String
  tipo        String
  fechaCarga  DateTime @default(now())
}

model Mensaje {
  id          Int       @id @default(autoincrement())
  solicitudId Int
  solicitud   Solicitud @relation(fields: [solicitudId], references: [id])
  remitenteId Int
  remitente   Usuario   @relation(fields: [remitenteId], references: [id])
  contenido   String
  fechaEnvio  DateTime  @default(now())
}

model Resena {
  id             Int         @id @default(autoincrement())
  solicitudId    Int         @unique
  solicitud      Solicitud   @relation(fields: [solicitudId], references: [id])
  organizadorId  Int
  organizador    Organizador @relation(fields: [organizadorId], references: [id])
  bandaId        Int
  banda          Banda       @relation(fields: [bandaId], references: [id])
  calificacion   Int
  comentario     String?
  respuestaBanda String?
  fechaCreacion  DateTime    @default(now())
}

model Pago {
  id                       Int       @id @default(autoincrement())
  solicitudId              Int       @unique
  solicitud                Solicitud @relation(fields: [solicitudId], references: [id])
  montoTotal               Float
  comision                 Float
  tipo                     String    @default("anticipo_y_saldo")
  porcentajeAnticipo       Int       @default(50)
  estadoPagoUno            String    @default("pendiente")
  estadoPagoDos            String    @default("pendiente")
  stripePaymentIntentUno   String?
  stripePaymentIntentDos   String?
  fechaHabilitacionPagoDos DateTime?
  notificado48h            Boolean   @default(false)
  estadoPagoBandaUno       String    @default("pendiente")
  estadoPagoBandaDos       String    @default("pendiente")
  montoTransferidoUno      Float?
  montoTransferidoDos      Float?
  fechaCreacion            DateTime  @default(now())
}