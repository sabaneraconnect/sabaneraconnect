// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id              Int       @id @default(autoincrement())
  nombre          String
  correo          String    @unique
  contrasena      String
  telefono        String
  rol             String
  estado          String    @default("pendiente")
  intentosFallidos Int      @default(0)
  bloqueadoHasta  DateTime?
  fechaCreacion   DateTime  @default(now())

  banda           Banda?
  organizador     Organizador?
}

model Organizador {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @unique
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  fechaCreacion DateTime @default(now())
}

model Banda {
  id                   Int               @id @default(autoincrement())
  usuarioId            Int               @unique
  usuario              Usuario           @relation(fields: [usuarioId], references: [id])
  municipio            String
  departamento         String?
  nit                  String?
  estadoVerificacion   String            @default("borrador")
  integrantes          String?
  generos              String?
  municipiosCobertura  String?
  aniosExperiencia     Int               @default(0)
  estadoPerfil         String            @default("borrador")
  multimedia           MultimediaBanda[]
  disponibilidad       DisponibilidadBanda[]
}

model DisponibilidadBanda {
  id            Int      @id @default(autoincrement())
  bandaId       Int
  banda         Banda    @relation(fields: [bandaId], references: [id])
  fecha         DateTime
  franjaInicio  String
  franjaFin     String
  estado        String   @default("disponible")
}

model MultimediaBanda {
  id          Int      @id @default(autoincrement())
  bandaId     Int
  banda       Banda    @relation(fields: [bandaId], references: [id])
  url         String
  tipo        String
  fechaCarga  DateTime @default(now())
}